generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Rol {
  ADMIN
  PILOTO
}

enum Disciplina {
  RALLY
  CIRCUITO
  DRIFT
  KARTCROSS
  MONOPLAZA
}

enum Simulador {
  ASSETTO_CORSA
  EA_WRC
  DIRT_RALLY
  F1_24
  BEAMNG
}

enum EstadoCampeonato {
  PROXIMO
  ACTIVO
  FINALIZADO
}

enum EstadoCarrera {
  PROGRAMADA
  EN_CURSO
  FINALIZADA
}

enum EstadoInscripcion {
  PENDIENTE
  CONFIRMADA
  CANCELADA
}

enum CanalChat {
  GENERAL
  RALLY
  CIRCUITO
  DRIFT
  ANUNCIOS
}

enum TipoNotificacion {
  CARRERA_PROXIMA
  RESULTADO_PUBLICADO
  INSCRIPCION_CONFIRMADA
  NUEVA_CARRERA
  NUEVO_CAMPEONATO
  SUSCRIPCION_ACTIVA
  SUSCRIPCION_CANCELADA
}

enum PlanSuscripcion {
  ROOKIE
  AMATEUR
  PRO
  ELITE
}

enum EstadoSuscripcion {
  ACTIVA
  CANCELADA
  EXPIRADA
  PENDIENTE
  GRATUITA
}

enum UbicacionPatrocinador {
  LANDING
  SIDEBAR
  CAMPEONATOS
  ACADEMIA
  TODAS
}

enum TipoQueja {
  INCIDENCIA_CARRERA
  QUEJA_GENERAL
}

enum EstadoQueja {
  ABIERTA
  EN_REVISION
  RESUELTA
  ARCHIVADA
}

enum TipoSancion {
  ADVERTENCIA
  PENALIZACION_PUNTOS
  EXCLUSION_CARRERA
  SUSPENSION_TEMPORAL
  BAN_PERMANENTE
}

model User {
  id             String    @id @default(cuid())
  username       String    @unique
  email          String    @unique
  emailVerified  DateTime?
  password       String?
  role           Rol       @default(PILOTO)
  avatar         String?
  pais           String?
  bio            String?
  silenciado     Boolean   @default(false)
  baneado        Boolean   @default(false)
  motivoBan      String?
  fechaRegistro  DateTime  @default(now())
  totalPuntos    Int       @default(0)
  totalCarreras  Int       @default(0)
  totalVictorias Int       @default(0)
  totalPodios    Int       @default(0)

  accounts            Account[]
  sessions            Session[]
  inscripciones       Inscripcion[]
  resultados          Resultado[]
  mensajes            MensajeChat[]
  notificaciones      Notificacion[]
  suscripcion         Suscripcion?
  cochesDesbloqueados CocheDesbloqueado[]
  accionesAdmin       LogAccionAdmin[]    @relation("AdminAcciones")
  accionesRecibidas   LogAccionAdmin[]    @relation("TargetAcciones")
  clasesVistas        ClaseVista[]
  quejasPresentadas   Queja[]             @relation("QuejaDenunciante")
  quejasRecibidas     Queja[]             @relation("QuejaDenunciado")
  pruebasAportadas    PruebaQueja[]

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Campeonato {
  id          String           @id @default(cuid())
  nombre      String
  disciplina  Disciplina
  simulador   Simulador
  descripcion String
  estado      EstadoCampeonato @default(PROXIMO)
  fechaInicio DateTime
  fechaFin    DateTime
  maxPilotos  Int              @default(20)
  imagen      String?
  modsReq     String?
  creadoEn    DateTime         @default(now())

  carreras      Carrera[]
  inscripciones Inscripcion[]
  sistemaPuntos SistemaPuntos[]

  @@map("campeonatos")
}

model Carrera {
  id               String        @id @default(cuid())
  campeonatoId     String
  nombre           String
  circuito         String
  fecha            DateTime
  duracionMin      Int           @default(60)
  estado           EstadoCarrera @default(PROGRAMADA)
  servidorIP       String?
  servidorPassword String?
  transmisionUrl   String?
  modsRequeridos   String?

  vueltas         Int?
  coche           String?
  linkModCircuito String?
  linkModCoche    String?
  origenSheet     Boolean @default(false)

  campeonato Campeonato  @relation(fields: [campeonatoId], references: [id], onDelete: Cascade)
  resultados Resultado[]
  quejas     Queja[]

  @@map("carreras")
}

model Inscripcion {
  id               String            @id @default(cuid())
  userId           String
  campeonatoId     String
  estado           EstadoInscripcion @default(PENDIENTE)
  fechaInscripcion DateTime          @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  campeonato Campeonato @relation(fields: [campeonatoId], references: [id], onDelete: Cascade)

  @@unique([userId, campeonatoId])
  @@map("inscripciones")
}

model Resultado {
  id           String   @id @default(cuid())
  carreraId    String
  userId       String
  posicion     Int
  puntos       Int      @default(0)
  vueltaRapida Boolean  @default(false)
  abandono     Boolean  @default(false)
  tiempo       String?
  creadoEn     DateTime @default(now())

  carrera Carrera @relation(fields: [carreraId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([carreraId, userId])
  @@map("resultados")
}

model SistemaPuntos {
  id           String @id @default(cuid())
  campeonatoId String
  posicion     Int
  puntos       Int

  campeonato Campeonato @relation(fields: [campeonatoId], references: [id], onDelete: Cascade)

  @@unique([campeonatoId, posicion])
  @@map("sistema_puntos")
}

model MensajeChat {
  id        String    @id @default(cuid())
  userId    String
  canal     CanalChat @default(GENERAL)
  contenido String
  eliminado Boolean   @default(false)
  creadoEn  DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("mensajes_chat")
}

model Notificacion {
  id       String           @id @default(cuid())
  userId   String
  tipo     TipoNotificacion
  mensaje  String
  leida    Boolean          @default(false)
  link     String?
  creadoEn DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notificaciones")
}

model Suscripcion {
  id                    String            @id @default(cuid())
  userId                String            @unique
  plan                  PlanSuscripcion
  estado                EstadoSuscripcion @default(ACTIVA)
  precioMensual         Float
  fechaInicio           DateTime          @default(now())
  fechaRenovacion       DateTime
  fechaCancelacion      DateTime?
  esGratuita            Boolean           @default(false)
  fechaExpiracionManual DateTime?
  planAnterior          PlanSuscripcion?
  notasAdmin            String?
  paypalSubscriptionId  String?           @unique
  paypalOrderId         String?
  creadoEn              DateTime          @default(now())
  actualizadoEn         DateTime          @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("suscripciones")
}

model Coche {
  id          String          @id @default(cuid())
  nombre      String
  disciplina  Disciplina
  planMinimo  PlanSuscripcion
  descripcion String?
  imagen      String?
  modAC       String?
  activo      Boolean         @default(true)
  creadoEn    DateTime        @default(now())

  desbloqueos CocheDesbloqueado[]

  @@map("coches")
}

model CocheDesbloqueado {
  id       String   @id @default(cuid())
  userId   String
  cocheId  String
  creadoEn DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  coche Coche @relation(fields: [cocheId], references: [id], onDelete: Cascade)

  @@unique([userId, cocheId])
  @@map("coches_desbloqueados")
}

model LogAccionAdmin {
  id           String   @id @default(cuid())
  adminId      String
  targetUserId String
  accion       String
  detalle      String?
  creadoEn     DateTime @default(now())

  admin  User @relation("AdminAcciones", fields: [adminId], references: [id])
  target User @relation("TargetAcciones", fields: [targetUserId], references: [id])

  @@map("log_acciones_admin")
}

model Queja {
  id     String      @id @default(cuid())
  tipo   TipoQueja
  estado EstadoQueja @default(ABIERTA)

  denuncianteId String
  denunciante   User   @relation("QuejaDenunciante", fields: [denuncianteId], references: [id])

  denunciadoId String?
  denunciado   User?   @relation("QuejaDenunciado", fields: [denunciadoId], references: [id])

  carreraId String?
  carrera   Carrera? @relation(fields: [carreraId], references: [id])

  titulo         String
  descripcion    String
  vuelta         Int?
  linkRepeticion String?

  pruebas PruebaQueja[]

  resolucion        String?
  sancion           TipoSancion?
  puntosPenalizados Int?
  diasSuspension    Int?
  resueltaPor       String?
  fechaResolucion   DateTime?

  creadoEn      DateTime @default(now())
  actualizadoEn DateTime @updatedAt

  @@map("quejas")
}

model PruebaQueja {
  id          String   @id @default(cuid())
  quejaId     String
  queja       Queja    @relation(fields: [quejaId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  descripcion String
  linkPrueba  String?
  creadoEn    DateTime @default(now())

  @@map("pruebas_queja")
}

model SyncLog {
  id          String   @id @default(cuid())
  ejecutadoEn DateTime @default(now())
  creadas     Int
  omitidas    Int
  errores     String?
  tipo        String   @default("AUTOMATICA")

  @@map("sync_logs")
}

model Clase {
  id            String       @id @default(cuid())
  titulo        String
  descripcion   String?
  disciplina    Disciplina
  youtubeUrl    String
  duracionMin   Int?
  orden         Int          @default(0)
  publicada     Boolean      @default(false)
  creadoEn      DateTime     @default(now())
  actualizadoEn DateTime     @updatedAt
  vistas        ClaseVista[]

  @@map("clases")
}

model Patrocinador {
  id            String                  @id @default(cuid())
  nombre        String
  descripcion   String?
  logoUrl       String?
  linkExterno   String?
  ubicaciones   UbicacionPatrocinador[]
  activo        Boolean                 @default(true)
  esColaborador Boolean                 @default(false)
  orden         Int                     @default(0)
  creadoEn      DateTime                @default(now())
  actualizadoEn DateTime                @updatedAt

  @@map("patrocinadores")
}

model ClaseVista {
  id       String   @id @default(cuid())
  userId   String
  claseId  String
  vistoCEn DateTime @default(now())
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  clase    Clase    @relation(fields: [claseId], references: [id], onDelete: Cascade)

  @@unique([userId, claseId])
  @@map("clases_vistas")
}
